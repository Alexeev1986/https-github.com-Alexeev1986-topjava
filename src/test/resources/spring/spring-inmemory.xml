<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="inMemoryUserRepository" class="ru.javawebinar.topjava.repository.inmemory.InMemoryUserRepository"/>
    <bean id="inMemoryMealRepository" class="ru.javawebinar.topjava.repository.inmemory.InMemoryMealRepository"/>

    <bean id="userService" class="ru.javawebinar.topjava.service.UserService">
        <constructor-arg ref="inMemoryUserRepository"/>
    </bean>

    <bean id="mealService" class="ru.javawebinar.topjava.service.MealService">
        <constructor-arg ref="inMemoryMealRepository"/>
    </bean>
</beans>